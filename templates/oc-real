#!/usr/bin/env bash
# oc-real — single-command launcher for sst/opencode (productized engine).
#
# Auto-wired (no effort from Alex):
#   - MemPalace `wake-up` injected into agent context every launch
#   - SK nutshell (last 50 beats) injected into agent context every launch
#   - SK beat fired: session_start, heartbeat every 15 min, session_end
#   - All 3 providers (OpenRouter / HuggingFace / NVIDIA) selectable via OC_PROVIDER
#
# Usage:
#   oc-real                                 # TUI in current dir
#   oc-real "fix the failing test"          # one-shot prompt
#   OC_PROVIDER=huggingface oc-real         # different provider
#
# Pre-flight files maintained by this script:
#   ~/.config/opencode/_session_brief.md   ← regenerated each launch
#   ~/.config/opencode/_heartbeat.pid      ← PID of background heartbeat
#   ~/.config/opencode/logs/sk-beat.log    ← beat send log

set -uo pipefail

export PATH="$HOME/.opencode/bin:$HOME/.local/bin:$PATH"

if ! command -v opencode >/dev/null 2>&1; then
  echo "❌ opencode not installed — run: oc-real-install"
  exit 1
fi

# Load provider keys
set -a
[ -f "$HOME/.env.openrouter" ]  && . "$HOME/.env.openrouter"
[ -f "$HOME/.env.huggingface" ] && . "$HOME/.env.huggingface"
[ -f "$HOME/.env.nvidia" ]      && . "$HOME/.env.nvidia"
set +a

# Provider/model selection
OC_PROVIDER="${OC_PROVIDER:-openrouter}"
case "$OC_PROVIDER" in
  openrouter)  MODEL="${OC_MODEL:-openrouter/z-ai/glm-5.1}" ;;
  huggingface) MODEL="${OC_MODEL:-huggingface/Qwen/Qwen3-Coder-480B-A35B-Instruct}" ;;
  nvidia)      MODEL="${OC_MODEL:-nvidia/z-ai/glm-5.1}" ;;
  *) echo "❌ Unknown OC_PROVIDER=$OC_PROVIDER (openrouter|huggingface|nvidia)"; exit 1 ;;
esac

CONFIG_DIR="$HOME/.config/opencode"
LOG_DIR="$CONFIG_DIR/logs"
mkdir -p "$LOG_DIR"
SK_LOG="$LOG_DIR/sk-beat.log"
BRIEF="$CONFIG_DIR/_session_brief.md"
HEARTBEAT_PID="$CONFIG_DIR/_heartbeat.pid"

SESSION_ID="oc-$(date +%Y%m%d-%H%M%S)-$$"
SK_AGENT="${SK_BEAT_AGENT:-oc-real}"
SK_KEY="${SK_BEAT_TOKEN:-bb_youClRMsvnGINKuZPY9Jh053DIeomErj}"
SK_URL="https://sk-mcp.bebond.net/mcp"
VERHAAL_URL="${VERHAAL_URL:-https://verhaal.bebond.net/beat}"

# ── SK beat helper (direct MCP call, env-var-passed to python for safe quoting) ──
sk_beat() {
  local beat_type="$1"; local content="$2"
  local payload
  payload=$(SK_AGENT="$SK_AGENT" SK_BT="$beat_type" SK_CONTENT="$content" \
            SK_SID="$SESSION_ID" SK_PROV="$OC_PROVIDER" SK_MODEL="$MODEL" \
    python3 -c '
import json, os, sys
print(json.dumps({
  "jsonrpc":"2.0","id":1,"method":"tools/call",
  "params":{
    "name":"beat_write",
    "arguments":{
      "agent":   os.environ["SK_AGENT"],
      "beat_type": os.environ["SK_BT"],
      "content": os.environ["SK_CONTENT"],
      "metadata":{
        "session_id": os.environ["SK_SID"],
        "provider":   os.environ["SK_PROV"],
        "model":      os.environ["SK_MODEL"],
      },
    },
  },
}))')
  curl -sS --max-time 8 -X POST "$SK_URL" \
    -H "Authorization: Bearer $SK_KEY" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json, text/event-stream" \
    -d "$payload" >>"$SK_LOG" 2>&1 || true
  echo "[$(date -u +%FT%TZ)] beat $beat_type — sent" >>"$SK_LOG"
}

# ── Build session brief: MemPalace wake-up + SK nutshell ─────────
{
  echo "# Session brief — auto-generated by oc-real at $(date -u +%FT%TZ)"
  echo ""
  echo "Session: \`$SESSION_ID\`  ·  Provider: \`$OC_PROVIDER\`  ·  Model: \`$MODEL\`"
  echo ""
  echo "## MemPalace wake-up"
  echo ""
  echo '```'
  mempalace wake-up 2>/dev/null | head -200 || echo "(mempalace unavailable)"
  echo '```'
  echo ""
  echo "## Recent SK beats (last 50)"
  echo ""
  echo '```'
  curl -sS --max-time 12 -X POST "$SK_URL" \
    -H "Authorization: Bearer $SK_KEY" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json, text/event-stream" \
    -d '{"jsonrpc":"2.0","id":1,"method":"tools/call","params":{"name":"nutshell_get","arguments":{"limit":50}}}' 2>/dev/null \
    | sed -n '/^data:/p' | head -1 | sed 's/^data: //' \
    | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('result',{}).get('content',[{}])[0].get('text',''))
except Exception:
    print('(nutshell fetch failed)')" 2>/dev/null
  echo '```'
  echo ""
  echo "## Wiki status"
  echo ""
  if mountpoint -q "$HOME/vaults/eed" 2>/dev/null; then
    echo "✅ wiki mounted at \`~/vaults/eed/\`"
  else
    echo "⚠ wiki not mounted — type \`mount-eed\` in another terminal if you need vault access"
  fi
} > "$BRIEF"

# ── session_start beat ────────────────────────────────────────────
sk_beat "session_start" "oc-real session $SESSION_ID started: $OC_PROVIDER/$MODEL"

# ── Background heartbeat (every 15 min) ───────────────────────────
(
  while true; do
    sleep 900
    sk_beat "heartbeat" "oc-real $SESSION_ID still alive"
  done
) >/dev/null 2>&1 &
HB_PID=$!
echo "$HB_PID" > "$HEARTBEAT_PID"

# ── On exit: kill heartbeat + session_end beat ────────────────────
cleanup() {
  RC=$?
  if [ -f "$HEARTBEAT_PID" ]; then
    PID=$(cat "$HEARTBEAT_PID" 2>/dev/null)
    [ -n "$PID" ] && kill "$PID" 2>/dev/null || true
    rm -f "$HEARTBEAT_PID"
  fi
  sk_beat "session_end" "oc-real session $SESSION_ID ended (rc=$RC)"
  exit $RC
}
trap cleanup EXIT INT TERM

cat <<EOF
══════════════════════════════════════════════════════════════
  🧠 oc-real (sst/opencode)  ·  ${MODEL}  ·  ${OC_PROVIDER}
══════════════════════════════════════════════════════════════
  Session: ${SESSION_ID}
  Brief:   ${BRIEF}  (MemPalace wake-up + SK nutshell — auto-loaded)
  SK:      session_start beat sent · heartbeat every 15 min · session_end on exit
  MCPs:    bbtracker · aio · sk · bbdev · bbdocs · inkoop
  Wiki:    $(mountpoint -q "$HOME/vaults/eed" 2>/dev/null && echo 'mounted ✅' || echo 'not mounted (run: mount-eed)')
══════════════════════════════════════════════════════════════

EOF

if [ $# -eq 0 ]; then
  opencode --model "$MODEL"
else
  opencode run --model "$MODEL" "$@"
fi
